# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/timesheet-tracker-db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRE_HOURS=24

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://3scsolution.atlassian.net
JIRA_EMAIL=anand.verma@3scsolution.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=
JIRA_CLIENT_FIELD=customfield_10233
JIRA_POD_FIELD=customfield_10193

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM_NAME=Engineering Analytics Platform

# ── Anthropic AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── App ───────────────────────────────────────────────────────────────────────
# true = OTP shown in API response (dev only), false = real email sent
DEV_MODE=true
FRONTEND_URL=http://localhost:3000
SYNC_INTERVAL_MINUTES=30
