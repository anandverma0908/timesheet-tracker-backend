# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trackly:trackly@localhost:5432/trackly
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── NOVA / Ollama ─────────────────────────────────────────────────────────────
NOVA_MODEL=llama3.1:8b
NOVA_BASE_URL=http://ollama:11434
NOVA_temperature=0
NOVA_MAX_TOKENS=1500
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Trackly
APP_VERSION=1.0.0
DEBUG=false
DEV_MODE=true
FRONTEND_URL=http://localhost:3000

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=10485760

# ── Background jobs ───────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=30

# ── Code context repo sources ────────────────────────────────────────────────
# Optional local repo mapping for multi-project code context.
# Format:
# CODE_CONTEXT_LOCAL_REPOS=name|/absolute/path/to/repo|org/repo;name2|/absolute/path/to/repo2|org/repo2
# CODE_CONTEXT_REPO_SEARCH_ROOTS=/absolute/path/containing/repos
CODE_CONTEXT_LOCAL_REPOS=
CODE_CONTEXT_REPO_SEARCH_ROOTS=

# ── GitHub code review ──────────────────────────────────────────────────────
# GITHUB_REPOS is a comma-separated allowlist used by Repo Health Scan and PR Reviews.
GITHUB_TOKEN=
GITHUB_REPOS=
GITHUB_WEBHOOK_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_EMAIL=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Trackly
